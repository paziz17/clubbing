# ============================================================
# CLUBBING · LOCAL-ONLY environment · v1.3
# Copy to .env. Defaults below work out-of-the-box (demo mode).
# ============================================================

# ---- Database (SQLite — file lives at prisma/dev.db) ----
DATABASE_URL="file:./dev.db"

# ---- NextAuth (bliner side) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-please-change"
NEXTAUTH_URL="http://localhost:3000"

# ---- Venue CRM session (separate JWT secret) ----
VENUE_SESSION_SECRET="dev-venue-secret-please-change"

# ============================================================
#  OAuth providers — Social login API integration
# ============================================================
# Each is optional. Without keys the UI falls back to GUEST mode.
# After adding keys + restarting the dev server, the corresponding
# button on /auth becomes a real OAuth login.
#
# REDIRECT URI to register at the provider console (one per provider):
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/facebook
#   http://localhost:3000/api/auth/callback/instagram
# (When deploying, swap the host for your real domain.)
# ============================================================

# ---- Google OAuth ----
# Console: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" of type "Web application".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Facebook Login ----
# Console: https://developers.facebook.com/apps
# Add product "Facebook Login" → settings → Valid OAuth Redirect URIs.
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ---- Instagram Basic Display ----
# Console: https://developers.facebook.com/apps → "Instagram Basic Display".
# Add an Instagram Test User from the App Roles → Roles tab.
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""

# ============================================================
#  Other integrations (all optional, demo mode by default)
# ============================================================

# ---- Stripe (sliqah / card processing) ----
# FREE POC: use Stripe TEST MODE keys (sk_test_... / pk_test_...). Test mode is
# completely free, never charges real money, and accepts Stripe test cards
# (e.g. 4242 4242 4242 4242, any future date, any CVC).
#
# Flow when a key is set:
#   checkout -> hosted Stripe Checkout -> redirect back to /tickets/[id]?session_id=...
#   The success page reconciles the session (marks the reservation PAID), and the
#   webhook below confirms it server-side as a backup.
#
# Without these keys, payment falls back to DEMO mode (auto-confirms reservations).
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Optional but recommended in production. Get it from `stripe listen` (local) or
# the Stripe Dashboard -> Developers -> Webhooks (endpoint: /api/stripe/webhook,
# event: checkout.session.completed). If empty, the webhook still works but skips
# signature verification, and the success-page reconciliation covers confirmation.
STRIPE_WEBHOOK_SECRET=""
STRIPE_ISSUING_ENABLED=""

# ---- WhatsApp Business Cloud API (Club Bot campaigns) ----
# Without these, campaigns return wa.me deeplinks to open manually.
WHATSAPP_PHONE_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ---- Email (Resend) ----
# Without this, emails are logged to the dev console.
RESEND_API_KEY=""
EMAIL_FROM="CLUBBING <noreply@clubbing.local>"
