# Database — Postgres (נדרש ל-Vercel)
# מקומי: צור DB חינם ב-https://neon.tech
# Vercel: Storage → Create Database → Neon
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
AUTH_SECRET=your-secret-min-32-chars
AUTH_URL=https://clubbing-two.vercel.app
NEXTAUTH_URL=https://clubbing-two.vercel.app

# כתובת האתר המלאה (לשיתוף, קישורים וכו')
NEXT_PUBLIC_APP_URL=https://clubbing-two.vercel.app

# OAuth — התחברות עם רשתות חברתיות (ראה OAUTH-SETUP.md)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=
# AUTH_INSTAGRAM_ID=   # הערה: Instagram Basic Display הופסק ע"י Meta
# AUTH_INSTAGRAM_SECRET=

# Facebook Events (אופציונלי)
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_IDS=

# Admin CRM (בעלי מועדונים) — ברירת מחדל: admin/admin
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_SECRET=random-secret-for-session-cookie
