# Database — Postgres (נדרש ל-Vercel)
# מקומי: צור DB חינם ב-https://neon.tech
# Vercel: Storage → Create Database → Neon
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
AUTH_SECRET=your-secret-min-32-chars
AUTH_URL=https://your-app.vercel.app

# OAuth (אופציונלי)
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_INSTAGRAM_ID=
# AUTH_INSTAGRAM_SECRET=

# Facebook Events (אופציונלי)
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_IDS=

# Admin CRM (בעלי מועדונים) — ברירת מחדל: admin/admin
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_SECRET=random-secret-for-session-cookie
