# כניסת מפתח ב־/auth: בפיתוח וב־*.vercel.app מופיעה אוטומטית.
# true = תמיד (גם דומיין משלך). false = לכבות גם ב־Vercel.
# NEXT_PUBLIC_DEV_LOGIN=true
# NEXT_PUBLIC_DEV_LOGIN=false

# Database — Postgres (נדרש ל-Vercel)
# מקומי: צור DB חינם ב-https://neon.tech
# Vercel: Storage → Create Database → Neon
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
AUTH_SECRET=your-secret-min-32-chars
AUTH_URL=https://clubbing-two.vercel.app
NEXTAUTH_URL=https://clubbing-two.vercel.app

# כתובת האתר המלאה (לשיתוף, קישורים וכו')
NEXT_PUBLIC_APP_URL=https://clubbing-two.vercel.app

# OAuth — התחברות עם רשתות חברתיות (ראה OAUTH-SETUP.md)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=
# AUTH_INSTAGRAM_ID=   # הערה: Instagram Basic Display הופסק ע"י Meta
# AUTH_INSTAGRAM_SECRET=

# מייל אימות הרשמה (אופציונלי — בלי זה הקוד יודפס לקונסול בפיתוח)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# Facebook Events (אופציונלי)
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_IDS=

# מנהל מערכת — כניסה ב-/admin/login (CRM על כל המועדונים). ברירת מחדל: admin / admin
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-in-production
# ADMIN_SECRET=long-random-string-same-for-venue-cookies

# הערה: אותו ADMIN_SECRET חותם גם על עוגיית כניסת מועדון (/venue/login)
